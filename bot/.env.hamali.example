# ===========================================================
#  HamaliVpn — конфигурация бота Bedolaga
#  Скопируй в .env репозитория Bedolaga и заполни значения.
#  Секреты (BOT_TOKEN, *_SECRET, пароли) НЕ коммитить и не слать в чат.
# ===========================================================

# --- Бот и админ ---
BOT_TOKEN=PASTE_FROM_BOTFATHER          # секрет, из @BotFather
ADMIN_IDS=YOUR_TELEGRAM_ID              # твой числовой Telegram ID (@userinfobot)
BOT_USERNAME=HamaliVpn_bot              # @username бота без @
SUPPORT_USERNAME=@HamaliVpnSupport      # куда писать в поддержку
DEBUG=false

# --- Подключение к панели Remnawave ---
REMNAWAVE_API_URL=https://panel.hamalivpn.com
REMNAWAVE_API_KEY=PASTE_PANEL_API_TOKEN # сгенерировать в панели → API Tokens
REMNAWAVE_AUTH_TYPE=api_key

# --- База данных (PostgreSQL) ---
DATABASE_MODE=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bedolaga
POSTGRES_USER=bedolaga
POSTGRES_PASSWORD=CHANGE_ME_STRONG       # openssl rand -hex 16

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CART_TTL_SECONDS=3600

# --- Веб-сервер и вебхуки (нужен HTTPS, ставим Caddy перед :8080) ---
BOT_RUN_MODE=webhook
WEBHOOK_URL=https://bot.hamalivpn.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET_TOKEN=GENERATE_openssl_rand_hex_32
WEB_API_ENABLED=true
WEB_API_HOST=0.0.0.0
WEB_API_PORT=8080
WEB_API_DEFAULT_TOKEN=GENERATE_openssl_rand_hex_32
WEB_API_ALLOWED_ORIGINS=https://hamalivpn.com

# --- Оплата: Telegram Stars (без ИП, мгновенно) ---
TELEGRAM_STARS_ENABLED=true
TELEGRAM_STARS_RATE_RUB=1.4              # 1 звезда ≈ N рублей, подстроить

# --- Оплата: Platega (СБП / QR / карты, без своего ИП) ---
PLATEGA_ENABLED=true
PLATEGA_MERCHANT_ID=PASTE                # из кабинета Platega
PLATEGA_SECRET=PASTE                     # секрет, из кабинета Platega
PLATEGA_DISPLAY_NAME=Картой / СБП
PLATEGA_CURRENCY=RUB

# --- Реферальная программа: пригласивший получает 100 ₽ ---
REFERRAL_PROGRAM_ENABLED=true
REFERRAL_INVITER_BONUS_KOPEKS=10000      # 100 ₽ за приведённого клиента
REFERRAL_FIRST_TOPUP_BONUS_KOPEKS=0
REFERRAL_COMMISSION_PERCENT=0
REFERRAL_WITHDRAWAL_ENABLED=true
REFERRAL_WITHDRAWAL_MIN_AMOUNT_KOPEKS=30000   # вывод от 300 ₽

# --- Подписки / триал ---
TRIAL_DURATION_DAYS=3
TRIAL_TRAFFIC_LIMIT_GB=20
TRIAL_DEVICE_LIMIT=1
TRIAL_PAYMENT_ENABLED=false
DEFAULT_DEVICE_LIMIT=2
AVAILABLE_SUBSCRIPTION_PERIODS=30,90,365  # 1 мес / 3 мес / 1 год
ENABLE_AUTOPAY=true
DEFAULT_AUTOPAY_ENABLED=true

# --- Режим продаж и лимиты ---
SALES_MODE=tariffs                       # фиксированные тарифы (под лендинг)
DEFAULT_TRAFFIC_RESET_STRATEGY=MONTH     # сброс трафика раз в месяц
MAX_DEVICES_LIMIT=10                      # потолок устройств на подписку
PRICE_PER_DEVICE=5000                     # доп. устройство = 50 ₽/мес

# --- Брендинг и интерфейс (HamaliVpn) ---
PAYMENT_SERVICE_NAME=HamaliVpn
PAYMENT_SUBSCRIPTION_DESCRIPTION=Подписка HamaliVpn
PAYMENT_BALANCE_DESCRIPTION=Пополнение баланса HamaliVpn
ENABLE_LOGO_MODE=true
LOGO_FILE=hamali_logo.png                 # положить PNG-лого по этому пути
MAIN_MENU_MODE=cabinet                    # премиальный Mini App-кабинет
MENU_LAYOUT_ENABLED=true                  # drag-and-drop редактор меню
CONNECT_BUTTON_MODE=miniapp_subscription  # кнопка «Подключить» → автоподключение по ОС

# Примечание: тарифы (349/899/2990 ₽) и лимиты устройств заводятся в
# ВЕБ-АДМИНКЕ из bot/tariffs.hamali.json. Тексты — bot/branding/texts.ru.md.
