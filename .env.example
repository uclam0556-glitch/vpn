APP_NAME=HamaliVpn
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
AUTO_CREATE_SCHEMA=false

# Hostname without protocol. Before buying a domain use SERVER_IP.sslip.io.
PUBLIC_HOST=203.0.113.10.sslip.io
PUBLIC_BASE_URL=https://203.0.113.10.sslip.io
PANEL_HOST=panel.203.0.113.10.sslip.io

POSTGRES_DB=hamalivpn
POSTGRES_USER=hamalivpn
POSTGRES_PASSWORD=GENERATE_WITH_OPENSSL
REDIS_URL=redis://redis:6379/0

BOT_TOKEN=PASTE_ON_SERVER_ONLY
BOT_USERNAME=HamaliVpn_bot
ADMIN_TELEGRAM_IDS=PASTE_YOUR_NUMERIC_TELEGRAM_ID
SUPPORT_USERNAME=HamaliVpn_bot

ADMIN_USERNAME=admin
ADMIN_PASSWORD=GENERATE_WITH_OPENSSL
SESSION_SECRET=GENERATE_WITH_OPENSSL
SECURE_COOKIES=true

# Keep true until the real Remnawave API token and squad are ready.
REMNAWAVE_MOCK=true
PANEL_BASE_URL=http://remnawave:3000
REMNAWAVE_API_TOKEN=PASTE_ON_SERVER_ONLY
REMNAWAVE_INTERNAL_SQUADS=

TRIAL_DURATION_MINUTES=90
TRIAL_TRAFFIC_GB=30
TRIAL_DEVICE_LIMIT=1
SUBSCRIPTION_NAME=HamaliVpn
